# ─── Auth (NextAuth v5) ──────────────────────────────────
AUTH_SECRET=                           # Required: openssl rand -hex 32
AUTH_URL=https://your-domain.com       # Required: your production URL
AUTH_TRUST_HOST=true

# Google OAuth (optional — enables Google login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email — choose ONE provider:

# Option A: Resend (managed email service)
AUTH_RESEND_KEY=                       # Resend API key

# Option B: SMTP (any provider — Gmail, Outlook, Amazon SES, etc.)
SMTP_HOST=                             # e.g. smtp.gmail.com
SMTP_PORT=587                          # 587 for TLS, 465 for SSL
SMTP_SECURE=false                      # true for port 465
SMTP_USER=                             # SMTP username
SMTP_PASS=                             # SMTP password

# Option C: No config → emails printed to console (dev mode)

# Sender address (used by all providers)
EMAIL_FROM="KLLAPP <noreply@your-domain.com>"

# ─── Database ────────────────────────────────────────────
POSTGRES_URL=postgresql://user:pass@localhost:5432/kllapp

# ─── Liveblocks (real-time collaboration) ────────────────
LIVEBLOCKS_SECRET_KEY=                 # Required: sk_...
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=     # Required: pk_...

# ─── AI Features (optional) ─────────────────────────────
ANTHROPIC_API_KEY=                     # Optional: sk-ant-... (disables AI if absent)

# ─── S3 Object Storage (optional — file uploads) ────────
S3_ENDPOINT=                           # Optional: S3-compatible endpoint
S3_BUCKET=kllapp
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Redis (optional — improves caching) ────────────────
REDIS_URL=

# ─── Super Admin ─────────────────────────────────────────
SUPER_ADMIN_EMAIL=                     # Optional: email to grant super-admin on deploy
